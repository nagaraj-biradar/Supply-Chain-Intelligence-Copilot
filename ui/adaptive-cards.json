            {
              "type": "ColumnSet",
              "columns": [
                {
                  "width": "stretch",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Annual Savings",
                      "weight": "bolder",
                      "size": "small",
                      "color": "accent"
                    },
                    {
                      "type": "TextBlock",
                      "text": "${annual_savings}",
                      "spacing": "none",
                      "size": "large",
                      "weight": "bolder",
                      "color": "good"
                    }
                  ]
                },
                {
                  "width": "stretch",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Implementation Cost",
                      "weight": "bolder",
                      "size": "small",
                      "color": "accent"
                    },
                    {
                      "type": "TextBlock",
                      "text": "${implementation_cost}",
                      "spacing": "none"
                    }
                  ]
                }
              ]
            },
            {
              "type": "ColumnSet",
              "columns": [
                {
                  "width": "stretch",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "ROI",
                      "weight": "bolder",
                      "size": "small",
                      "color": "accent"
                    },
                    {
                      "type": "TextBlock",
                      "text": "${roi}%",
                      "spacing": "none",
                      "size": "large",
                      "weight": "bolder",
                      "color": "good"
                    }
                  ]
                },
                {
                  "width": "stretch",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Payback Period",
                      "weight": "bolder",
                      "size": "small",
                      "color": "accent"
                    },
                    {
                      "type": "TextBlock",
                      "text": "${payback_period} months",
                      "spacing": "none"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },

    "metrics-card": {
      "schema": "http://adaptivecards.io/schemas/adaptive-card.json",
      "type": "AdaptiveCard",
      "version": "1.4",
      "body": [
        {
          "type": "Container",
          "style": "accent",
          "body": [
            {
