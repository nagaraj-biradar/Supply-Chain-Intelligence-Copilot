                      "color": "accent"
                    },
                    {
                      "type": "TextBlock",
                      "text": "${active_suppliers}",
                      "spacing": "none",
                      "size": "large",
                      "weight": "bolder"
                    }
                  ]
                },
                {
                  "width": "stretch",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "High-Risk Suppliers",
                      "weight": "bolder",
                      "size": "small",
                      "color": "accent"
                    },
                    {
                      "type": "TextBlock",
                      "text": "${high_risk_suppliers}",
                      "spacing": "none",
                      "size": "large",
                      "weight": "bolder",
                      "color": "warning"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}
