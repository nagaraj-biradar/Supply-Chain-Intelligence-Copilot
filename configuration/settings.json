{
  "settings": {
    "copilot": {
      "name": "Supply Chain Intelligence Copilot",
      "displayLanguage": "en-US",
      "timezone": "UTC",
      "businessHours": {
        "enabled": false,
        "startTime": "08:00",
        "endTime": "18:00",
        "weekdays": [1, 2, 3, 4, 5]
      }
    },
    "nlp": {
      "confidenceThreshold": 0.75,
      "fallbackResponse": "I'm not sure I understand. Could you rephrase that?",
      "contextWindow": 5,
      "languageModel": "gpt-4-turbo",
      "intentRecognitionThreshold": 0.8
    },
    "queryDefaults": {
      "defaultTimeframe": "this-month",
      "defaultMetrics": [
        "on-time-delivery",
        "quality-rating",
        "cost-efficiency",
        "inventory-turn",
        "request-fulfillment"
      ],
      "maxRecords": 1000,
      "queryTimeout": 30000,
      "maxRecommendations": 10
    },
    "dataSources": {
      "erp": {
        "enabled": true,
        "refreshInterval": 3600,
        "timeout": 30,
        "retryAttempts": 3,
        "batchSize": 5000
      },
      "wms": {
        "enabled": true,
        "refreshInterval": 1800,
        "timeout": 30,
        "retryAttempts": 3,
        "realtimeEnabled": true
      },
      "oms": {
        "enabled": true,
        "refreshInterval": 3600,
        "timeout": 30,
        "retryAttempts": 3,
        "realtimeEnabled": true
      },
      "tms": {
        "enabled": true,
        "refreshInterval": 300,
        "timeout": 30,
        "retryAttempts": 3,
        "realtimeEnabled": true
      }
    },
    "features": {
      "orderTracking": {
        "enabled": true,
        "realtime": true,
        "exceptionDetection": true
      },
      "inventoryVisibility": {
        "enabled": true,
        "multiLocation": true,
        "ageTracking": true
      },
      "supplierAnalytics": {
        "enabled": true,
        "riskScoring": false,
        "performanceComparison": true,
        "trendAnalysis": true
      },
      "demandForecasting": {
        "enabled": false,
        "confidenceIntervals": true,
        "seasonalityFactors": true,
        "modelVersion": "prophet-v1"
      },
      "costAnalysis": {
        "enabled": false,
        "procurementAnalysis": true,
        "logisticsAnalysis": true,
        "inventoryCostCalculation": true
      },
      "riskAssessment": {
        "enabled": false,
        "supplierFinancialRisk": true,
        "supplyDisruptionRisk": true,
        "qualityRisk": true
      }
    },
    "reporting": {
      "automatedReports": {
        "enabled": true,
        "defaultFormat": "pdf",
        "defaultFrequency": "monthly",
        "excelExportEnabled": true,
        "csvExportEnabled": true
      },
      "dashboards": {
        "enabled": true,
        "refreshInterval": 300,
        "maxDataPoints": 10000,
        "visualization": "interactive"
      },
      "scheduling": {
        "enabled": true,
        "maxScheduledReports": 50,
        "emailNotifications": true,
        "teamsNotifications": true,
        "slackNotifications": true
      }
    },
    "analytics": {
      "mlModels": {
        "demandForecasting": {
          "enabled": false,
          "version": "v1.0",
          "accuracy": 0.92,
          "retrainFrequency": "monthly"
        },
        "supplierRiskScoring": {
          "enabled": false,
          "version": "v1.0",
          "accuracy": 0.88,
          "retrainFrequency": "quarterly"
        },
        "stockoutPrediction": {
          "enabled": false,
          "version": "v1.0",
          "accuracy": 0.85,
          "retrainFrequency": "monthly"
        },
        "exceptionDetection": {
          "enabled": false,
          "version": "v1.0",
          "accuracy": 0.9,
          "retrainFrequency": "monthly"
        }
      },
      "anomalyDetection": {
        "enabled": true,
        "sensitivityLevel": "medium",
        "alertOnAnomaly": true,
        "alertThreshold": 3.0
      }
    },
    "security": {
      "authentication": {
        "provider": "azure-ad",
        "mfaRequired": true,
        "mfaForPrivilegedUsers": true,
        "sessionTimeout": 28800,
        "idleTimeout": 1800,
        "maxConcurrentSessions": 3
      },
      "encryption": {
        "transportEncryption": "tls-1.3",
        "atRestEncryption": "aes-256",
        "keyRotation": "annual"
      },
      "dataClassification": {
        "enabled": true,
        "piiRedaction": true,
        "confidentialDataMasking": true
      },
      "auditLogging": {
        "enabled": true,
        "logLevel": "info",
        "retentionDays": 730
      }
    },
    "performance": {
      "caching": {
        "enabled": true,
        "provider": "redis",
        "ttl": 3600,
        "maxCacheSize": "10GB"
      },
      "rateLimit": {
        "enabled": true,
        "requestsPerMinute": 100,
        "requestsPerHour": 5000
      },
      "queryOptimization": {
        "enabled": true,
        "indexOptimization": true,
        "queryTimeout": 30000
      },
      "autoScaling": {
        "enabled": true,
        "minInstances": 3,
        "maxInstances": 20,
        "targetCpuUtilization": 70
      }
    },
    "notifications": {
      "alerts": {
        "enabled": true,
        "channels": ["email", "dashboard", "teams", "slack"]
      },
      "thresholds": {
        "supplierRiskCritical": 80,
        "supplierRiskHigh": 60,
        "stockoutRisk": 0.3,
        "deliveryDelay": 4,
        "qualityIssue": 5.0,
        "costVariance": 10.0
      },
      "escalation": {
        "enabled": true,
        "escalationPath": ["team-lead", "manager", "director", "executive"],
        "escalationTimeoutMinutes": 60
      }
    },
    "customization": {
      "branding": {
        "copilotName": "Supply Chain Intelligence Copilot",
        "logoUrl": "/assets/logo.png",
        "primaryColor": "#0078D4",
        "accentColor": "#107C10"
      },
      "userPreferences": {
        "allowCustomDashboards": true,
        "allowSavedQueries": true,
        "allowNotificationPreferences": true,
        "allowReportCustomization": true
      },
      "businessRules": {
        "minServiceLevel": 95,
        "minQualityScore": 90,
        "maxLeadTime": 30,
        "currencyDefault": "USD"
      }
    },
    "integrations": {
      "slack": {
        "enabled": false,
        "webhookUrl": "${SLACK_WEBHOOK_URL}",
        "channel": "#supply-chain-alerts",
        "notificationLevel": "high"
      },
      "teams": {
        "enabled": true,
        "webhookUrl": "${TEAMS_WEBHOOK_URL}",
        "channel": "Supply Chain Intelligence",
        "notificationLevel": "medium"
      },
      "email": {
        "enabled": true,
        "smtpServer": "${EMAIL_SMTP_SERVER}",
        "fromAddress": "supply-chain-copilot@company.com",
        "replyToAddress": "support@company.com"
      },
      "powerbi": {
        "enabled": false,
        "workspace": "Supply Chain Analytics",
        "apiKey": "${POWERBI_API_KEY}"
      },
      "salesforce": {
        "enabled": false,
        "instance": "${SALESFORCE_INSTANCE}",
        "clientId": "${SALESFORCE_CLIENT_ID}",
        "clientSecret": "${SALESFORCE_CLIENT_SECRET}"
      }
    },
    "monitoring": {
      "applicationInsights": {
        "enabled": true,
        "instrumentationKey": "${APP_INSIGHTS_KEY}",
        "sampleRate": 1.0
      },
      "healthCheck": {
        "enabled": true,
        "intervalSeconds": 60,
        "failureThreshold": 3
      },
      "metricsCollection": {
        "enabled": true,
        "retentionDays": 30,
        "granularity": "minute"
      }
    },
    "compliance": {
      "gdpr": {
        "enabled": true,
        "dataRetentionDays": 1095,
        "autoDeleteEnabled": true
      },
      "ccpa": {
        "enabled": true,
        "optOutEnabled": true,
        "dataAccessEnabled": true
      },
      "audit": {
        "enabled": true,
        "auditRetentionYears": 7,
        "immutableLogging": true
      }
    }
  }
}
