{
  "authentication": {
    "providers": [
      {
        "name": "azure-ad",
        "enabled": true,
        "default": true,
        "config": {
          "authority": "https://login.microsoftonline.com/${AZURE_TENANT_ID}",
          "clientId": "${AZURE_CLIENT_ID}",
          "clientSecret": "${AZURE_CLIENT_SECRET}",
          "redirectUri": "https://copilot.company.com/auth/callback",
          "scopes": ["api://supply-chain-copilot/access"],
          "cacheLocation": "sessionStorage",
          "persistCache": true
        }
      },
      {
        "name": "saml",
        "enabled": false,
        "config": {
          "entityId": "https://copilot.company.com",
          "assertionConsumerServiceURL": "https://copilot.company.com/saml/acs",
          "singleLogoutServiceURL": "https://copilot.company.com/saml/logout"
        }
      }
    ],
    "mfa": {
      "required": true,
      "requiredForRoles": [
        "admin",
        "procurement-manager",
        "operations-manager"
      ],
      "methods": ["authenticator-app", "sms", "email"],
      "rememberDeviceDays": 30
    },
    "sessionManagement": {
      "idleTimeout": 1800000,
      "absoluteTimeout": 28800000,
      "privilegedUserTimeout": 14400000,
      "maxConcurrentSessions": 3,
      "requireReauthForSensitiveData": true,
      "requireReauthTimeout": 3600000
    }
  },
  "authorization": {
    "rbac": {
      "enabled": true,
      "provider": "azure-ad",
      "roles": [
        {
          "id": "admin",
          "name": "Administrator",
          "description": "Full system access",
          "permissions": [
            "system:manage",
            "data:read",
            "data:write",
            "data:delete",
            "users:manage",
            "settings:manage",
            "audit:read"
          ]
        },
        {
          "id": "procurement-manager",
          "name": "Procurement Manager",
          "description": "Procurement and supplier management",
          "permissions": [
            "suppliers:read",
            "suppliers:write",
            "orders:read",
            "orders:write",
            "contracts:read",
            "contracts:write",
            "analytics:read",
            "reports:read",
            "reports:write"
          ]
        },
        {
          "id": "sc-analyst",
          "name": "Supply Chain Analyst",
          "description": "Supply chain analysis and optimization",
          "permissions": [
            "data:read",
            "analytics:read",
            "analytics:write",
            "reports:read",
            "reports:write",
            "forecasting:read",
            "optimization:read"
          ]
        },
        {
          "id": "logistics-manager",
          "name": "Logistics Manager",
          "description": "Logistics and transportation management",
          "permissions": [
            "shipments:read",
            "shipments:write",
            "logistics:read",
            "logistics:write",
            "analytics:read",
            "reports:read"
          ]
        },
        {
          "id": "operations-manager",
          "name": "Operations Manager",
          "description": "Operations and executive oversight",
          "permissions": [
            "data:read",
            "analytics:read",
            "reports:read",
            "dashboards:read",
            "audit:read"
          ]
        },
        {
          "id": "warehouse-manager",
          "name": "Warehouse Manager",
          "description": "Warehouse operations management",
          "permissions": [
            "inventory:read",
            "inventory:write",
            "warehouse:read",
            "warehouse:write",
            "analytics:read"
          ]
        }
      ]
    },
    "dataScoping": {
      "enabled": true,
      "rules": [
        {
          "role": "procurement-manager",
          "scope": "all",
          "restrictions": []
        },
        {
          "role": "logistics-manager",
          "scope": "shipments",
          "restrictions": ["cannot_modify_pricing", "cannot_modify_suppliers"]
        },
        {
          "role": "warehouse-manager",
          "scope": "location",
          "restrictions": ["limited_to_warehouse", "cannot_modify_procurement"]
        }
      ]
    }
  },
  "dataHandling": {
    "encryption": {
      "inTransit": {
        "protocol": "tls-1.3",
        "cipherSuites": [
          "TLS_AES_256_GCM_SHA384",
          "TLS_CHACHA20_POLY1305_SHA256"
        ],
        "enforceHttpsOnly": true,
        "hstsEnabled": true,
        "hstsMaxAge": 31536000
      },
      "atRest": {
        "algorithm": "aes-256-gcm",
        "keyManagement": "azure-keyvault",
        "keyRotationPolicy": "annual"
      }
    },
    "piiHandling": {
      "enabled": true,
      "classification": {
        "names": "high",
        "emails": "high",
        "phones": "high",
        "addresses": "medium",
        "financialData": "very-high"
      },
      "redaction": {
        "enabled": true,
        "redactInLogs": true,
        "redactInReports": true,
        "redactInExports": true
      },
      "retention": {
        "piiRetentionDays": 1095,
        "autoDeleteEnabled": true
      }
    },
    "dataResidency": {
      "required": true,
      "allowedRegions": ["us-east", "us-west", "eu-west", "eu-central"],
      "blockCrossRegionTransfer": true
    }
  },
  "auditLogging": {
    "enabled": true,
    "storage": "azure-immutable-blob",
    "retention": {
      "auditLogs": 2555,
      "accessLogs": 365,
      "changeLog": 730
    },
    "events": [
      "login",
      "logout",
      "data_access",
      "data_modification",
      "data_deletion",
      "configuration_change",
      "permission_change",
      "export",
      "report_generation",
      "failed_authentication"
    ],
    "logFormat": "json",
    "includeContextInfo": true
  },
  "monitoring": {
    "anomalyDetection": {
      "enabled": true,
      "indicators": [
        "unusual_login_location",
        "multiple_failed_auth",
        "unusual_data_access_volume",
        "unusual_data_access_pattern",
        "bulk_export_attempt",
        "after_hours_access"
      ]
    },
    "alerting": {
      "enabled": true,
      "channels": ["email", "slack", "teams"],
      "recipients": ["security-team@company.com"]
    }
  },
  "compliance": {
    "standards": ["soc2-type2", "gdpr", "ccpa"],
    "dataProcessingAgreement": {
      "required": true,
      "generationAutomated": true
    },
    "privacyNotice": {
      "required": true,
      "displayOnLogin": true
    },
    "dataSubjectRights": {
      "accessEnabled": true,
      "correctionEnabled": true,
      "deletionEnabled": true,
      "portabilityEnabled": true,
      "responseTimeHours": 72
    }
  }
}
